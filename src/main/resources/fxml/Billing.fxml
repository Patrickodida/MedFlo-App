<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.hms.ui.BillingController"
            styleClass="screen-root">

    <!-- ── TOP BAR ─────────────────────────────────────── -->
    <top>
        <HBox styleClass="topbar"
              alignment="CENTER_LEFT"
              spacing="14">
            <Button text="← Back"
                    onAction="#handleBack"
                    styleClass="btn-secondary"
                    style="-fx-padding:5 12;"/>
            <Label text="Billing and Payments"
                   styleClass="topbar-title"
                   HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel"
                   text=""
                   wrapText="true"
                   maxWidth="350"/>
        </HBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.38">

            <!-- LEFT: Bill Form -->
            <ScrollPane fitToWidth="true">
                <VBox styleClass="form-container" spacing="12">

                    <Label text="Create / Edit Bill"
                           style="-fx-font-size:15px;
                                  -fx-font-weight:bold;
                                  -fx-text-fill:#1A237E;"/>

                    <!-- Patient -->
                    <VBox spacing="4">
                        <Label text="Select Patient *"
                               styleClass="field-label"/>
                        <ComboBox fx:id="patientCombo"
                                  maxWidth="Infinity"
                                  styleClass="form-field"/>
                    </VBox>

                    <!-- Amounts -->
                    <HBox spacing="10">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Total Amount (UGX) *"
                                   styleClass="field-label"/>
                            <TextField fx:id="totalAmountField"
                                       promptText="e.g. 50000"
                                       styleClass="form-field"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Discount (UGX)"
                                   styleClass="field-label"/>
                            <TextField fx:id="discountField"
                                       promptText="0"
                                       styleClass="form-field"/>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Tax (UGX)"
                                   styleClass="field-label"/>
                            <TextField fx:id="taxField"
                                       promptText="0"
                                       styleClass="form-field"/>
                        </VBox>
                    </HBox>

                    <!-- Final Amount -->
                    <VBox spacing="4"
                          style="-fx-background-color:#E8F5E9;
                                 -fx-padding:10;
                                 -fx-background-radius:8;">
                        <Label text="Final Amount"
                               styleClass="field-label"/>
                        <Label fx:id="finalAmountLabel"
                               text="UGX 0"
                               style="-fx-font-size:22px;
                                      -fx-font-weight:bold;
                                      -fx-text-fill:#2E7D32;"/>
                    </VBox>

                    <!-- Payment Mode -->
                    <VBox spacing="4">
                        <Label text="Payment Mode"
                               styleClass="field-label"/>
                        <ComboBox fx:id="paymentModeCombo"
                                  maxWidth="Infinity"
                                  styleClass="form-field"/>
                    </VBox>

                    <!-- Notes -->
                    <VBox spacing="4">
                        <Label text="Notes"
                               styleClass="field-label"/>
                        <TextField fx:id="notesField"
                                   promptText="Optional notes..."
                                   styleClass="form-field"/>
                    </VBox>

                    <!-- Action Buttons -->
                    <HBox spacing="8">
                        <Button fx:id="createBtn"
                                text="Create Bill"
                                onAction="#handleCreate"
                                styleClass="btn-primary"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"/>
                        <Button fx:id="updateBtn"
                                text="Update Bill"
                                onAction="#handleUpdate"
                                styleClass="btn-primary"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"
                                visible="false"/>
                    </HBox>

                    <HBox spacing="8">
                        <Button text="Mark as Paid"
                                onAction="#handleMarkPaid"
                                styleClass="btn-primary"
                                style="-fx-background-color:#2E7D32;"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"/>
                        <Button text="Delete"
                                onAction="#handleDelete"
                                styleClass="btn-danger"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"/>
                        <Button text="Clear"
                                onAction="#handleClear"
                                styleClass="btn-secondary"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"/>
                    </HBox>

                </VBox>
            </ScrollPane>

            <!-- RIGHT: Bills Table -->
            <VBox spacing="10" styleClass="table-container">
                <Label text="All Bills"
                       style="-fx-font-size:14px;
                              -fx-font-weight:bold;
                              -fx-text-fill:#1A237E;"/>
                <TableView fx:id="billTable"
                           VBox.vgrow="ALWAYS"
                           styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="idCol"
                                     text="ID"
                                     prefWidth="45"/>
                        <TableColumn fx:id="patientCol"
                                     text="Patient"
                                     prefWidth="160"/>
                        <TableColumn fx:id="totalCol"
                                     text="Total"
                                     prefWidth="90"/>
                        <TableColumn fx:id="finalCol"
                                     text="Final"
                                     prefWidth="90"/>
                        <TableColumn fx:id="statusCol"
                                     text="Status"
                                     prefWidth="80"/>
                        <TableColumn fx:id="dateCol"
                                     text="Date"
                                     prefWidth="100"/>
                    </columns>
                    <placeholder>
                        <Label text="No bills found."
                               style="-fx-text-fill:#90A4AE;"/>
                    </placeholder>
                </TableView>
            </VBox>

        </SplitPane>
    </center>

</BorderPane>